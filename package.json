{
  "name": "ai-usage-widget",
  "version": "0.1.12",
  "private": false,
  "author": "Elisardo González Agulla",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "tauri": "node scripts/run-tauri.mjs",
    "tauri:dev": "node scripts/tauri-preflight.mjs && node scripts/run-tauri.mjs dev",
    "tauri:build": "node scripts/tauri-preflight.mjs && node scripts/run-tauri.mjs build",
    "tauri:probe:clear": "node scripts/tauri-preflight.mjs && env VITE_TRANSPARENCY_PROBE=clear node scripts/run-tauri.mjs dev",
    "tauri:probe:panel": "node scripts/tauri-preflight.mjs && env VITE_TRANSPARENCY_PROBE=panel node scripts/run-tauri.mjs dev",
    "tauri:probe:solid": "node scripts/tauri-preflight.mjs && env VITE_TRANSPARENCY_PROBE=solid node scripts/run-tauri.mjs dev",
    "test": "node --test backend/cliFailure.test.js backend/geminiPty.test.js backend/parser.test.js backend/platform.test.js"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  },
  "description": "Local-first desktop widget for Codex, Claude Code, and Gemini CLI usage",
  "homepage": "https://odrasile.github.io/ai-usage-widget/",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/odrasile/ai-usage-widget.git"
  },
  "bugs": {
    "url": "https://github.com/odrasile/ai-usage-widget/issues"
  },
  "keywords": [
    "ai-usage",
    "ai-usage-widget",
    "codex",
    "codex-cli",
    "claude-code",
    "claude-usage",
    "gemini-cli",
    "tauri",
    "desktop-widget",
    "usage-monitor",
    "local-first",
    "cross-platform"
  ]
}
