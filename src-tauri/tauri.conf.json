{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Usage Widget",
  "version": "0.1.6",
  "identifier": "com.monitorai.usagewidget",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "create": false,
        "title": "AI Usage Widget",
        "width": 540,
        "height": 204,
        "minWidth": 470,
        "minHeight": 132,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": [
      "../backend/**/*",
      "../node_modules/node-pty/**/*"
    ]
  }
}
